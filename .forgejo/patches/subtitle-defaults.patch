+++ b/src/scripts/settings/appSettings.js
@@ -166,7 +166,7 @@ class AppSettings {
             return this.set('alwaysBurnInSubtitleWhenTranscoding', val.toString());
         }

-        return toBoolean(this.get('alwaysBurnInSubtitleWhenTranscoding'), false);
