From: Soultaco83 <soulnacho@gmail.com>
Date: Wed, 14 May 2026 00:00:00 -0500
Subject: [PATCH] Add Clear Site Data toolbar button

Adds a trashcan icon button to the left of the SyncPlay button in the
toolbar. Clears localStorage, sessionStorage, all Cache API entries,
unregisters service workers, and deletes all IndexedDB databases
(Chromium) or known DB names (Firefox fallback), then reloads.

diff --git a/src/apps/experimental/components/AppToolbar/ClearSiteDataButton.tsx b/src/apps/experimental/components/AppToolbar/ClearSiteDataButton.tsx
new file mode 100644
--- /dev/null
+++ b/src/apps/experimental/components/AppToolbar/ClearSiteDataButton.tsx
@@ -0,0 +1,28 @@
+import DeleteOutline from '@mui/icons-material/DeleteOutline';
+import IconButton from '@mui/material/IconButton';
+import Tooltip from '@mui/material/Tooltip';
+import React, { useCallback } from 'react';
+
+import globalize from 'lib/globalize';
+import Dashboard from 'utils/dashboard';
+
+const ClearSiteDataButton = () => {
+    const onClick = useCallback(() => {
+        void Dashboard.clearSiteData();
+    }, []);
+
+    return (
+        <Tooltip title={globalize.translate('ButtonClearSiteData')}>
+            <IconButton
+                size='large'
+                aria-label={globalize.translate('ButtonClearSiteData')}
+                onClick={onClick}
+                color='inherit'
+            >
+                <DeleteOutline />
+            </IconButton>
+        </Tooltip>
+    );
+};
+
+export default ClearSiteDataButton;
